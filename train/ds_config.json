{
  "optimizer": {
    "type": "AdamW",
    "params": {
      "lr": 1e-6,
      "weight_decay": 0.1
    }
  },
  "zero_optimization": {
    "stage": 3,
    "contiguous_gradients": true,
    "overlap_comm": true,
    "reduce_scatter": true,
    "offload_optimizer": {
      "device": "cpu",
      "pin_memory": true
    },
    "stage3_gather_16bit_weights_on_model_save": true
  }
}
